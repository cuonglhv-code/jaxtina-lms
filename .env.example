# Supabase — get values from `supabase start` output (local) or supabase.com dashboard (cloud)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here_never_expose

# Anthropic — https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# App
NEXT_PUBLIC_APP_URL=https://your-domain.com
